---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
    author: CollectionEntry<'author'>
}

const {author} = Astro.props;
---

<div class="max-w-lg mx-auto bg-gray-800 rounded-lg shadow-md p-5">
    <div class="w-25 h-25 rounded-full mx-auto overflow-clip">
        <Image
            class="mx-auto scale-110"
            src={author.data.avatar}
            width={100}
            height={100}
            alt="Profile picture"
        />
    </div>
    <h2 class="text-center text-2xl font-semibold mt-3 text-gray-200">
        John Doe
    </h2>
    <p class="text-center text-gray-400 mt-1">Software Engineer</p>
    <div class="flex justify-center mt-5">
        <a
            href={author.data.twitter}
            class="text-blue-500 hover:text-blue-700 mx-3">Twitter</a
        >
        <a
            href={author.data.linkedIn}
            class="text-blue-500 hover:text-blue-700 mx-3">LinkedIn</a
        >
        <a
            href={author.data.github}
            class="text-blue-500 hover:text-blue-700 mx-3">GitHub</a
        >
    </div>
    <div class="mt-5">
        <h3 class="text-xl font-semibold text-gray-300">Bio</h3>
        <p class="text-gray-400 mt-2">
            John is a software engineer with over 10 years of experience in
            developing web and mobile applications. He is skilled in JavaScript,
            React, and Node.js.
        </p>
        <div class=""><a href={`/blog/${""}}`} class=""></a></div>
    </div>
</div>
